# Optional environment configuration for manual server startup.
# The Windows launcher intentionally clears inherited AI env vars so first launch uses in-app settings.
# To use these variables, start the server manually with `npm start` or `node ai-town-v2-server.js`.

AI_TOWN_V2_PORT=8788
AI_TOWN_API_KEYS=
AI_TOWN_BASE_URL=https://api.openai.com/v1
AI_TOWN_MODEL=gpt-4.1-mini
AI_TOWN_MAX_CONCURRENT_PER_KEY=5
AI_TOWN_TIMEOUT_MS=180000
AI_TOWN_MAX_REQUEST_BODY_BYTES=10000000
AI_TOWN_RETRY_DELAY_MS=300
