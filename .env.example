# 手动启动服务时可参考这些环境变量。
# Windows 启动脚本会故意清空继承的 AI 环境变量，让首次打开进入应用内配置。
# 如需使用这些变量，请用 `npm start` 或 `node ai-town-v2-server.js` 手动启动。

AI_TOWN_V2_PORT=8788
# 本地 AI 可把 Key 留空，例如 Ollama: http://localhost:11434/v1，LM Studio: http://localhost:1234/v1
AI_TOWN_API_KEYS=
AI_TOWN_BASE_URL=https://api.openai.com/v1
AI_TOWN_MODEL=gpt-4.1-mini
AI_TOWN_MAX_CONCURRENT_PER_KEY=5
AI_TOWN_TIMEOUT_MS=180000
AI_TOWN_MAX_REQUEST_BODY_BYTES=10000000
AI_TOWN_RETRY_DELAY_MS=300
